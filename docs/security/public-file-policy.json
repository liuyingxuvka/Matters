{
  "schema": "matters.public-file-policy.v1",
  "required_public_inventory": "docs/security/required-public-inventory.json",
  "allowed_paths": [
    ".agents/skills/**",
    ".codex/skills/**",
    ".flowguard/adoption_log.jsonl",
    ".flowguard/behavior_commitment_ledger/**",
    ".flowguard/evidence/**",
    ".flowguard/project.toml",
    ".github/**",
    ".gitignore",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "MANIFEST.in",
    "README.md",
    "SECURITY.md",
    "docs/**",
    "flowguard_design/**",
    "flowguard_models/**",
    "openspec/**",
    "plugin/**",
    "pyproject.toml",
    "scripts/**",
    "sbom.json",
    "src/**",
    "synthetic_fixtures/**",
    "tests/**",
    "ui/**"
  ],
  "forbidden_paths": [
    "**/.env",
    "**/.env.*",
    "**/*cookie*",
    "**/*credential*",
    "**/*.db",
    "**/*.db-*",
    "**/*.key",
    "**/*.log",
    "**/*.p12",
    "**/*.pem",
    "**/*.pfx",
    "**/*.sqlite",
    "**/*.sqlite3",
    "MATTERS_EVAL_VAULT/**",
    "MATTERS_HOME/**",
    "attachments/**",
    "blobs/**",
    "cache/**",
    "data/**",
    "embeddings/**",
    "indexes/**",
    "logs/**",
    "private/**",
    "receipts/**",
    "runtime/**",
    "screenshots/**",
    "thumbnails/**",
    "vault/**"
  ],
  "external_private_roots": [
    {
      "id": "MATTERS_HOME",
      "relative_path": "../MATTERS_HOME",
      "acl_disposition": "user_review_required",
      "encryption_disposition": "user_review_required",
      "cloud_sync_disposition": "user_review_required"
    },
    {
      "id": "MATTERS_EVAL_VAULT",
      "relative_path": "../MATTERS_EVAL_VAULT",
      "acl_disposition": "user_review_required",
      "encryption_disposition": "user_review_required",
      "cloud_sync_disposition": "user_review_required"
    }
  ],
  "maximum_public_file_bytes": 5242880
}
