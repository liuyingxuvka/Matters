{
  "schema": "matters.required-public-inventory.v1",
  "authority": "repository_public_source",
  "required_singletons": [
    ".gitignore",
    "AGENTS.md",
    "MANIFEST.in",
    "README.md",
    "docs/security/data-classification.md",
    "docs/security/public-boundary.md",
    "docs/security/public-file-policy.json",
    "docs/security/required-public-inventory.json",
    "docs/security/scope-manifest.yaml",
    "pyproject.toml",
    "scripts/check_public_boundary.py",
    "src/matters/__init__.py",
    "tests/test_tm18_privacy_public_boundary.py"
  ],
  "required_trees": [
    ".agents",
    ".codex",
    ".flowguard",
    "docs",
    "flowguard_design",
    "flowguard_models",
    "openspec",
    "plugin",
    "plugins",
    "scripts",
    "src",
    "synthetic_fixtures",
    "tests",
    "ui"
  ],
  "excluded_patterns": [
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/*.pyc",
    "**/*.pyo",
    "**/*.egg-info/**",
    "**/*.log",
    "**/*~",
    ".flowguard/evidence/ui/screenshots/**",
    ".flowguard/evidence/ui/**/screenshots/**"
  ],
  "fingerprint_excluded_patterns": [
    ".flowguard/adoption_log.jsonl",
    ".flowguard/evidence/**",
    "docs/flowguard_adoption_log.md"
  ],
  "package_projection": [
    {
      "source_prefix": "src/",
      "source_pattern": "src/matters/**",
      "wheel_prefix": ""
    }
  ],
  "wheel_data_projection": [
    {
      "source_path": "CHANGELOG.md",
      "wheel_data_path": "share/matters/CHANGELOG.md"
    },
    {
      "source_path": "SECURITY.md",
      "wheel_data_path": "share/matters/SECURITY.md"
    },
    {
      "source_path": "sbom.json",
      "wheel_data_path": "share/matters/sbom.json"
    },
    {
      "source_path": "ui/app.js",
      "wheel_data_path": "share/matters/ui/app.js"
    },
    {
      "source_path": "ui/index.html",
      "wheel_data_path": "share/matters/ui/index.html"
    },
    {
      "source_path": "ui/styles.css",
      "wheel_data_path": "share/matters/ui/styles.css"
    },
    {
      "source_path": "plugins/matters/.mcp.json",
      "wheel_data_path": "share/matters/plugins/matters/.mcp.json"
    },
    {
      "source_path": "plugins/matters/.codex-plugin/plugin.json",
      "wheel_data_path": "share/matters/plugins/matters/.codex-plugin/plugin.json"
    },
    {
      "source_path": "plugins/matters/skills/matters/SKILL.md",
      "wheel_data_path": "share/matters/plugins/matters/skills/matters/SKILL.md"
    },
    {
      "source_path": "plugins/matters/skills/matters/agents/openai.yaml",
      "wheel_data_path": "share/matters/plugins/matters/skills/matters/agents/openai.yaml"
    },
    {
      "source_path": "plugins/matters/skills/matters/references/service-contract.md",
      "wheel_data_path": "share/matters/plugins/matters/skills/matters/references/service-contract.md"
    }
  ],
  "sdist_excluded_patterns": [
    ".flowguard/adoption_log.jsonl",
    ".flowguard/evidence/**"
  ],
  "package_forbidden_patterns": [
    ".flowguard/adoption_log.jsonl",
    ".flowguard/evidence/**",
    "**/.flowguard/evidence/**",
    "screenshots/**",
    "**/screenshots/**",
    "receipts/**",
    "**/receipts/**",
    "MATTERS_HOME/**",
    "**/MATTERS_HOME/**",
    "MATTERS_EVAL_VAULT/**",
    "**/MATTERS_EVAL_VAULT/**"
  ],
  "release_required_singletons": [
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "sbom.json"
  ],
  "claim_boundary": "Selectors define the complete public source inventory from the physical workspace. Release-only files become mandatory only for a release scan. Ignored, tracked, clean-clone, and package inventories are comparisons, never replacement authorities."
}
